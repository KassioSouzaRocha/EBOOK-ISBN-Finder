[Desktop Entry]
Type=Application
Name=Renomear com ISBN
Comment=Renomeia livros PDF/EPUB/MOBI usando metadados do ISBN
Icon=document-edit
NoDisplay=true
Actions=SomenteEsseItem;Pasta;

[Desktop Action SomenteEsseItem]
Name=Somente esse item — Renomear com ISBN
Exec=bash -c 'INSTALL="INSTALL_DIR_PLACEHOLDER"; if command -v gnome-terminal &>/dev/null; then gnome-terminal -- bash -c "cd \"$INSTALL\" && uv run isbn.py --arquivo \"%F\"; echo; echo Pressione Enter para fechar...; read"; elif command -v xterm &>/dev/null; then xterm -hold -e bash -c "cd \"$INSTALL\" && uv run isbn.py --arquivo \"%F\""; else cd "$INSTALL" && uv run isbn.py --arquivo "%F" &; fi'
Icon=document-open
MimeType=application/pdf;application/epub+zip;application/x-mobipocket-ebook;

[Desktop Action Pasta]
Name=Renomear pasta inteira com ISBN
Exec=bash -c 'INSTALL="INSTALL_DIR_PLACEHOLDER"; if command -v gnome-terminal &>/dev/null; then gnome-terminal -- bash -c "cd \"$INSTALL\" && uv run isbn.py --pasta \"%F\"; echo; echo Pressione Enter para fechar...; read"; elif command -v xterm &>/dev/null; then xterm -hold -e bash -c "cd \"$INSTALL\" && uv run isbn.py --pasta \"%F\""; else cd "$INSTALL" && uv run isbn.py --pasta "%F" &; fi'
Icon=folder
MimeType=inode/directory;
