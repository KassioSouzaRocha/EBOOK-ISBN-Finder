#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# Script Nautilus: "Somente esse item — Renomear com ISBN"
# Instalar em: ~/.local/share/nautilus/scripts/Somente esse item — Renomear com ISBN
# Permissão:   chmod +x "~/.local/share/nautilus/scripts/Somente esse item — Renomear com ISBN"
# ─────────────────────────────────────────────────────────────────────────────
# O Nautilus passa os caminhos selecionados em NAUTILUS_SCRIPT_SELECTED_FILE_PATHS
# (um por linha). Este script detecta se é arquivo ou pasta e passa o argumento
# correto: --arquivo ou --pasta.
# Quando múltiplos arquivos são selecionados, processa cada um individualmente.
# ─────────────────────────────────────────────────────────────────────────────

# Diretório de instalação do ISBN Renamer (substituído pelo install.sh)
INSTALL_DIR="INSTALL_DIR_PLACEHOLDER"

# Coleta todos os arquivos selecionados
mapfile -t SELECIONADOS < <(echo "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS" | tr -d '\r' | grep -v '^$')

if [ ${#SELECIONADOS[@]} -eq 0 ]; then
    # Nada selecionado: abre diálogo interativo
    CMD="cd '$INSTALL_DIR' && uv run isbn.py; echo; echo 'Pressione Enter para fechar...'; read"
else
    # Monta a lista de argumentos --arquivo para cada item selecionado
    ARGS=""
    for ITEM in "${SELECIONADOS[@]}"; do
        if [ -f "$ITEM" ]; then
            ARGS="$ARGS --arquivo '$ITEM'"
        elif [ -d "$ITEM" ]; then
            # Se for pasta, processa como pasta (fallback)
            ARGS="$ARGS --pasta '$ITEM'"
        fi
    done
    CMD="cd '$INSTALL_DIR' && uv run isbn.py $ARGS; echo; echo 'Pressione Enter para fechar...'; read"
fi

# Abre terminal para exibir o progresso
if command -v gnome-terminal &>/dev/null; then
    gnome-terminal -- bash -c "$CMD"
elif command -v xterm &>/dev/null; then
    xterm -hold -e bash -c "$CMD"
else
    # Sem terminal gráfico: roda em background
    cd "$INSTALL_DIR" && eval "uv run isbn.py $ARGS" &
fi
